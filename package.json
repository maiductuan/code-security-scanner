{
  "name": "deepscan-cli",
  "version": "1.0.0",
  "description": "Open-source security & code quality scanner - combines SAST, SCA/CVE, and secrets detection in a single CLI tool",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "deepscan": "dist/bin/deepscan.js"
  },
  "scripts": {
    "dev": "tsx src/bin/deepscan.ts",
    "rules:update": "tsx scripts/update-rules.ts",
    "evaluate": "tsx scripts/evaluate.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "security",
    "scanner",
    "static-analysis",
    "sast",
    "sca",
    "cve",
    "code-quality",
    "vulnerability",
    "deepscan",
    "sonarqube-alternative"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "rules",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "consola": "^3.2.3",
    "glob": "^11.0.0",
    "ignore": "^6.0.2",
    "js-yaml": "^4.1.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
